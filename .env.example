# Database
DATABASE_URL=postgresql://experiments_user:experiments_dev_password@postgres:5432/experiments

# Firebase Authentication
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Application
APP_ENV=development
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://localhost:8001

# Logging
LOG_LEVEL=INFO

# Optional: Backup locations (for production)
BACKUP_DIR=./backups
PUBLIC_COPY_DIR=./public_copies

# Notion Sync — Reactor Dashboard
# Token from Notion integration settings (secret_...)
NOTION_TOKEN=
# Reactor Dashboard database ID (32-char UUID without dashes)
NOTION_DATABASE_ID=53ec4778508541efa31eaf0e4accac35
# Data source ID for the Reactor Dashboard
NOTION_DATA_SOURCE_ID=d8d499ab-d6ef-44ce-9f67-d650dfaf5319
# Hour (0-23, America/New_York) to run the daily sync
NOTION_SYNC_HOUR=6
