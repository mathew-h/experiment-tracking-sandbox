# Database
DATABASE_URL=postgresql://experiments_user:experiments_dev_password@postgres:5432/experiments

# Firebase Authentication
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Application
APP_ENV=development
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://localhost:8001

# Logging
LOG_LEVEL=INFO

# Optional: Backup locations (for production)
BACKUP_DIR=./backups
PUBLIC_COPY_DIR=./public_copies
